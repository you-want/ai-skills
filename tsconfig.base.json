{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@ai-skills/core": ["packages/core"],
      "@ai-skills/ship-safe": ["packages/skills/ship-safe"]
    },
    "types": ["node"]
  }
}